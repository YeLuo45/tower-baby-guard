; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BabyGuard Tower Defense"
config/description="A parenting-themed tower defense game for kids"
run/main_scene="res://src/scenes/level_select.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://src/core/game_state.gd"
Achievements="*res://src/systems/achievement_system.gd"
Persistence="*res://src/systems/persistence_system.gd"
AchievementPopup="*res://src/scenes/ui/achievement_popup.tscn"
AllianceSystem="*res://src/systems/alliance_system.gd"
ComboSystem="*res://src/systems/combo_system.gd"
UpgradeSystem="*res://src/systems/upgrade_system.gd"
LevelLoader="*res://src/systems/level_loader.gd"
StorySystem="*res://src/systems/story_system.gd"
EventSystem="*res://src/systems/event_system.gd"
AudioManager="*res://src/systems/audio_manager.gd"
ScreenShake="*res://src/systems/screen_shake.gd"
WorldProgress="*res://src/systems/world_progress.gd"
WeatherManager="*res://src/systems/weather_manager.gd"
ParticleWeather="*res://src/systems/particle_weather.gd"
WeatherEffects="*res://src/systems/weather_effects.gd"
EndlessManager="*res://src/systems/endless_manager.gd"
ReplaySystem="*res://src/systems/replay_system.gd"
ChallengeSeeder="*res://src/systems/challenge_seeder.gd"
SkillSystem="*res://src/systems/skill_system.gd"
SkillUnlock="*res://src/systems/skill_unlock.gd"
CollectionSystem="*res://src/systems/collection_system.gd"
CollectionRewards="*res://src/systems/collection_rewards.gd"
FriendSystem="*res://src/systems/friend_system.gd"
GachaSystem="*res://src/systems/gacha_system.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

place_tower={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(105, 11),"global_position":Vector2(109, 52),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}
cancel_action={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}
start_wave={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
