anchor_right = 1.0
offset_top = 60.0
offset_bottom = 120.0
theme_override_colors/font_color = Color(1, 0.9, 0.7, 1)
theme_override_font_sizes/font_size = 42
text = "Select Level"
horizontal_alignment = 1

[node name="LevelGrid" type="HBoxContainer" parent="."]
anchors_preset = 14
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 0.5
offset_top = -150.0
offset_bottom = 150.0
theme_override_constants/separation = 40
alignment = 1

[node name="Level1" type="VBoxContainer" parent="LevelGrid"]
